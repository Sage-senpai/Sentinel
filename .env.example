# ============================================================
#  SENTINEL — Environment Variables Template
#  Copy to .env and fill in your values
#  NEVER commit the filled .env file
# ============================================================

# ── General ────────────────────────────────────────────────
ENVIRONMENT=development

# ── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_FUUL_PROJECT_ID=
NEXT_PUBLIC_ALERT_REGISTRY_ADDRESS=

# ── Backend (FastAPI) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel_dev

# ── Pacifica ───────────────────────────────────────────────
PACIFICA_API_URL=https://test-api.pacifica.fi/api/v1
PACIFICA_WS_URL=wss://test-ws.pacifica.fi
PACIFICA_API_KEY=
PACIFICA_API_SECRET=

# ── Sponsor APIs ───────────────────────────────────────────
PRIVY_APP_SECRET=
ELFA_API_KEY=
FUUL_API_KEY=
COINGECKO_API_KEY=
RHINOFI_API_KEY=

# ── Smart Contracts ────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBISCAN_API_KEY=

# ── Agent Toggles ──────────────────────────────────────────
AGENT_GUARD_ENABLED=true
AGENT_CASCADE_ENABLED=true
AGENT_WHALE_ENABLED=true
AGENT_FUNDING_ENABLED=true
AGENT_AFRICA_ENABLED=true
AGENT_BROADCAST_ENABLED=true
